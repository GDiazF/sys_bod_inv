VITE_API_BASE_URL=/api/v1

# true = pantallas integradas con API usan mocks locales (sin llamadas HTTP)
# false = consume GET /api/v1/inventory/productos/ (ver src/api/README.md)
VITE_USE_API_MOCKS=true

# JWT de desarrollo (Bearer). Obtener con:
# curl -X POST http://127.0.0.1:8000/api/v1/auth/token/ -H "Content-Type: application/json" -d "{\"email\":\"...\",\"password\":\"...\"}"
VITE_API_ACCESS_TOKEN=
