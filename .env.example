DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sis_inventario
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIME_ZONE=America/Santiago
DEFAULT_FROM_EMAIL=noreply@example.com
AUTH_THROTTLE_RATE=20/minute

# Producción (config.settings.prod): definir obligatoriamente
# DJANGO_SECRET_KEY=<clave-segura>
# ALLOWED_HOSTS=api.ejemplo.com
# CORS_ALLOWED_ORIGINS=https://app.ejemplo.com
# CSRF_TRUSTED_ORIGINS=https://app.ejemplo.com
# DB_PASSWORD=<password-seguro>
# SECURE_SSL_REDIRECT=True
